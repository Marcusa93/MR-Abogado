# ============================================================
# Marco Rossi Estudio Jurídico — Variables de entorno
# Copiá este archivo como .env.local y completá los valores reales.
# NUNCA comitear .env.local ni archivos con claves reales.
# ============================================================

# ------------------------------------------------------------
# SUPABASE — Proyecto: Estudio Marco Rossi System
# Dashboard: https://supabase.com/dashboard/project/ftxpilbvjfxfkjkrbrnl
# ------------------------------------------------------------
SUPABASE_URL=https://ftxpilbvjfxfkjkrbrnl.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_MCP_URL=https://mcp.supabase.com/mcp?project_ref=ftxpilbvjfxfkjkrbrnl

# ------------------------------------------------------------
# FRONTEND (Vite) — prefijo VITE_ obligatorio para exposición al browser
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://ftxpilbvjfxfkjkrbrnl.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Push Notifications (VAPID) — generá con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ------------------------------------------------------------
# EDGE FUNCTIONS (Supabase secrets — aplicar con supabase secrets set)
# Estas variables se configuran via Dashboard o CLI, no en .env.local
# ------------------------------------------------------------
# supabase secrets set OPENROUTER_API_KEY=...
OPENROUTER_API_KEY=your-openrouter-api-key

# supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=...
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@marcorressiabogados.com.ar

# ------------------------------------------------------------
# SAE — Sistema de Actuación Electrónica (justucuman.gov.ar)
# Estas variables se configuran via Dashboard o CLI, no en .env.local
# ------------------------------------------------------------

# Clave AES-256 para cifrar contraseñas SAE en el servidor (64 hex chars = 32 bytes).
# Generada con: openssl rand -hex 32
# NUNCA cambiar una vez en producción (invalidaría todas las contraseñas guardadas).
# supabase secrets set SAE_ENCRYPTION_KEY=... --project-ref ftxpilbvjfxfkjkrbrnl
SAE_ENCRYPTION_KEY=d6b64664798c2256c25bd8b95c8c6822143981116f7754dcb97f075ea95cf3c6
